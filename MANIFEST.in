include LICENSE
include README.md
include pyproject.toml

recursive-include agentbox *.py py.typed

exclude .env
exclude .env.*
exclude Makefile
exclude docker-compose.yml
exclude Dockerfile.*
exclude environment.yml

prune daytona
prune planning
